server:
  port: 8080
spring:
  application:
    name: api-gateway
  cloud:
    gateway:
      server:
        webflux:
          routes:
            - id: ms-productos
              uri: http://ms-productos:8081
              predicates:
                - Path=/api/productos/**
            - id: ms-usuarios
              uri: http://ms-usuarios:8082
              predicates:
                - Path=/api/usuarios/**
            - id: ms-analisis
              uri: http://ms-analisis:8083
              predicates:
                - Path=/api/analisis/**
            - id: ms-recomendaciones
              uri: http://ms-recomendaciones:8084
              predicates:
                - Path=/api/recomendaciones/**
          globalcors:
            cors-configurations:
              '/**':
                allowedOrigins: "*"
                allowedMethods: "*"
                allowedHeaders: "*"